MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/xenura?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=hello@xenuralabs.com
# Comma-separated — include Vercel URL and custom domain(s)
FRONTEND_URL=https://your-site.vercel.app,https://www.xenuralabs.com,https://xenuralabs.com

# Resend (admin forgot-password emails) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Testing: Xenura Admin <onboarding@resend.dev>
# Production: verify your domain in Resend, then use e.g. Xenura Admin <noreply@xenuralabs.com>
RESEND_FROM=Xenura Admin <onboarding@resend.dev>
